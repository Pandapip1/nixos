From 67fc0066a5c017acc87235e074adf43d4fd60935 Mon Sep 17 00:00:00 2001
From: Gavin John <gavinnjohn@gmail.com>
Date: Thu, 16 Jul 2026 21:56:19 +0000
Subject: [PATCH] drm: add sysfs non_desktop_override for connectors

Add a per-connector sysfs file, non_desktop_override, that forces the
non-desktop KMS property to a given value.

The use case is a patch to Monado, an OpenXR runtime, to add
stereoscopic mode support for a particular pair of smart glasses (Xreal
Air, original). This requires that a specific USB HID command be sent,
which causes the glasses to declare a new EDID (which keeps the same
VID/PID) with a different set of modes, and also causes the output to
be split down the middle, with each half getting sent to each eye.

This is a simple override that sets non_desktop for the connector.
This means that extending this to more glasses types can be done
without subsequent kernel patches.

This is exposed via sysfs rather than debugfs, since the intent is for
userspace (Monado) to depend on it going forward, and debugfs carries
no ABI stability guarantee.

There are a couple of other approaches that would satisfy the use
case, but all of them require a non-trivial kernel patch. Adding a
mechanism that would allow adding the non-desktop quirk depending on
VID, PID, *and* the modes exposed by the EDID would work here and
would have some advantages, but would cause additional glasses support
to be blocked by the need to upstream the change to the quirk table,
and would also need careful handling for kernels that don't have the
quirk in their list.

Using the EDID override to create a modified EDID with a VID/PID
matching a monitor with a non-desktop quirk was considered. However,
this approach has a couple major issues. First, the non-desktop quirk
needs to be set *before* the mode switch, so that Wayland compositors
don't race with the code that sets the EDID override. But the updated
EDID is only available after the mode switch, so the SBS mode EDID has
to be hardcoded, which itself presents some issues. If this is done
wrong (maybe a new pair of glasses comes out with different timings
and the code doesn't recognize the difference), the result is a
rapidly flickering mess that produces different images in each eye.
This could be genuinely dangerous for some people, which makes it
immediately disqualifying. Secondly, this causes the display to be
reported incorrectly. Tooling that looks for the VID/PID pair used
would get confused, and the product corresponding to the VID/PID pair
would confuse the tooling that assumed it's the overridden glasses.

Signed-off-by: Gavin John <gavinnjohn@gmail.com>
---
 drivers/gpu/drm/drm_connector.c     | 39 ++++++++++++++++++++++++
 drivers/gpu/drm/drm_crtc_internal.h |  3 ++
 drivers/gpu/drm/drm_edid.c          |  7 +++++
 drivers/gpu/drm/drm_sysfs.c         | 46 +++++++++++++++++++++++++++++
 include/drm/drm_connector.h         | 16 +++++++++-
 5 files changed, 110 insertions(+), 1 deletion(-)

diff --git a/drivers/gpu/drm/drm_connector.c b/drivers/gpu/drm/drm_connector.c
index 11646453aaac..e821251e005b 100644
--- a/drivers/gpu/drm/drm_connector.c
+++ b/drivers/gpu/drm/drm_connector.c
@@ -286,6 +286,7 @@ static int drm_connector_init_only(struct drm_device *dev,
 	mutex_init(&connector->hdmi.infoframes.lock);
 	mutex_init(&connector->hdmi_audio.lock);
 	connector->edid_blob_ptr = NULL;
+	connector->non_desktop_override = DRM_NON_DESKTOP_OVERRIDE_UNSET;
 	connector->epoch_counter = 0;
 	connector->tile_blob_ptr = NULL;
 	connector->status = connector_status_unknown;
@@ -1178,6 +1179,13 @@ static const struct drm_prop_enum_list drm_panel_type_enum_list[] = {
 	{ DRM_MODE_PANEL_TYPE_OLED, "OLED" },
 };
 
+static const struct drm_prop_enum_list drm_non_desktop_override_enum_list[] = {
+	{ DRM_NON_DESKTOP_OVERRIDE_UNSET, "unset" },
+	{ DRM_NON_DESKTOP_OVERRIDE_OFF, "off" },
+	{ DRM_NON_DESKTOP_OVERRIDE_ON, "on" },
+};
+DRM_ENUM_NAME_FN(drm_get_non_desktop_override_name, drm_non_desktop_override_enum_list)
+
 /**
  * drm_display_info_set_bus_formats - set the supported bus formats
  * @info: display info to store bus formats in
@@ -3654,3 +3662,34 @@ void drm_connector_attach_panel_type_property(struct drm_connector *connector)
 	drm_object_attach_property(&connector->base, prop, DRM_MODE_PANEL_TYPE_UNKNOWN);
 }
 EXPORT_SYMBOL(drm_connector_attach_panel_type_property);
+
+int drm_connector_non_desktop_override_set(struct drm_connector *connector,
+					   enum drm_connector_non_desktop_override value)
+{
+	struct drm_device *dev = connector->dev;
+	int ret;
+
+	mutex_lock(&connector->edid_override_mutex);
+	connector->non_desktop_override = value;
+	if (value != DRM_NON_DESKTOP_OVERRIDE_UNSET)
+		connector->display_info.non_desktop =
+			(value == DRM_NON_DESKTOP_OVERRIDE_ON);
+	mutex_unlock(&connector->edid_override_mutex);
+
+	ret = drm_object_property_set_value(&connector->base,
+					    dev->mode_config.non_desktop_property,
+					    connector->display_info.non_desktop);
+	if (ret) {
+		drm_dbg_kms(dev, "[CONNECTOR:%d:%s] non-desktop property update failed (%d)\n",
+			    connector->base.id, connector->name, ret);
+		return ret;
+	}
+
+	drm_dbg_kms(dev, "[CONNECTOR:%d:%s] non-desktop override set to %s\n",
+		    connector->base.id, connector->name,
+		    drm_get_non_desktop_override_name(value));
+
+	drm_sysfs_connector_property_event(connector, dev->mode_config.non_desktop_property);
+
+	return 0;
+}
diff --git a/drivers/gpu/drm/drm_crtc_internal.h b/drivers/gpu/drm/drm_crtc_internal.h
index 83146ffef00c..277258a8b781 100644
--- a/drivers/gpu/drm/drm_crtc_internal.h
+++ b/drivers/gpu/drm/drm_crtc_internal.h
@@ -197,6 +197,9 @@ int drm_connector_create_standard_properties(struct drm_device *dev);
 const char *drm_get_connector_force_name(enum drm_connector_force force);
 void drm_connector_free_work_fn(struct work_struct *work);
 struct drm_connector *drm_connector_find_by_fwnode(struct fwnode_handle *fwnode);
+const char *drm_get_non_desktop_override_name(int val);
+int drm_connector_non_desktop_override_set(struct drm_connector *connector,
+					   enum drm_connector_non_desktop_override value);
 
 /* IOCTL */
 int drm_connector_property_set_ioctl(struct drm_device *dev,
diff --git a/drivers/gpu/drm/drm_edid.c b/drivers/gpu/drm/drm_edid.c
index df3c25bac761..df790c9495ce 100644
--- a/drivers/gpu/drm/drm_edid.c
+++ b/drivers/gpu/drm/drm_edid.c
@@ -6838,6 +6838,13 @@ static void update_display_info(struct drm_connector *connector,
 		info->non_desktop = true;
 	}
 
+	mutex_lock(&connector->edid_override_mutex);
+	if (connector->non_desktop_override != DRM_NON_DESKTOP_OVERRIDE_UNSET) {
+		info->non_desktop =
+			(connector->non_desktop_override == DRM_NON_DESKTOP_OVERRIDE_ON);
+	}
+	mutex_unlock(&connector->edid_override_mutex);
+
 	if (drm_edid_has_internal_quirk(connector, EDID_QUIRK_CAP_DSC_15BPP))
 		info->max_dsc_bpp = 15;
 
diff --git a/drivers/gpu/drm/drm_sysfs.c b/drivers/gpu/drm/drm_sysfs.c
index ef4e923a8728..ba89cf7282b8 100644
--- a/drivers/gpu/drm/drm_sysfs.c
+++ b/drivers/gpu/drm/drm_sysfs.c
@@ -303,11 +303,56 @@ static ssize_t connector_id_show(struct device *device,
 	return sysfs_emit(buf, "%d\n", connector->base.id);
 }
 
+static ssize_t non_desktop_override_show(struct device *device,
+					 struct device_attribute *attr,
+					 char *buf)
+{
+	struct drm_connector *connector = to_drm_connector(device);
+	enum drm_connector_non_desktop_override value;
+
+	mutex_lock(&connector->edid_override_mutex);
+	value = connector->non_desktop_override;
+	mutex_unlock(&connector->edid_override_mutex);
+
+	return sysfs_emit(buf, "%s\n", drm_get_non_desktop_override_name(value));
+}
+
+static ssize_t non_desktop_override_store(struct device *device,
+					  struct device_attribute *attr,
+					  const char *buf, size_t count)
+{
+	struct drm_connector *connector = to_drm_connector(device);
+	struct drm_device *dev = connector->dev;
+	enum drm_connector_non_desktop_override value;
+	int ret;
+
+	ret = mutex_lock_interruptible(&dev->mode_config.mutex);
+	if (ret)
+		return ret;
+
+	if (sysfs_streq(buf, "unset"))
+		value = DRM_NON_DESKTOP_OVERRIDE_UNSET;
+	else if (sysfs_streq(buf, "off"))
+		value = DRM_NON_DESKTOP_OVERRIDE_OFF;
+	else if (sysfs_streq(buf, "on"))
+		value = DRM_NON_DESKTOP_OVERRIDE_ON;
+	else
+		ret = -EINVAL;
+
+	if (!ret)
+		ret = drm_connector_non_desktop_override_set(connector, value);
+
+	mutex_unlock(&dev->mode_config.mutex);
+
+	return ret ? ret : count;
+}
+
 static DEVICE_ATTR_RW(status);
 static DEVICE_ATTR_RO(enabled);
 static DEVICE_ATTR_RO(dpms);
 static DEVICE_ATTR_RO(modes);
 static DEVICE_ATTR_RO(connector_id);
+static DEVICE_ATTR_RW(non_desktop_override);
 
 static struct attribute *connector_dev_attrs[] = {
 	&dev_attr_status.attr,
@@ -315,6 +360,7 @@ static struct attribute *connector_dev_attrs[] = {
 	&dev_attr_dpms.attr,
 	&dev_attr_modes.attr,
 	&dev_attr_connector_id.attr,
+	&dev_attr_non_desktop_override.attr,
 	NULL
 };
 
diff --git a/include/drm/drm_connector.h b/include/drm/drm_connector.h
index 5f5ca023cd65..a2a351956d8a 100644
--- a/include/drm/drm_connector.h
+++ b/include/drm/drm_connector.h
@@ -58,6 +58,12 @@ enum drm_connector_force {
 	DRM_FORCE_ON_DIGITAL, /* for DVI-I use digital connector */
 };
 
+enum drm_connector_non_desktop_override {
+	DRM_NON_DESKTOP_OVERRIDE_UNSET,
+	DRM_NON_DESKTOP_OVERRIDE_OFF, /* force non-desktop to false */
+	DRM_NON_DESKTOP_OVERRIDE_ON,  /* force non-desktop to true */
+};
+
 /**
  * enum drm_connector_status - status for a &drm_connector
  *
@@ -2260,7 +2266,15 @@ struct drm_connector {
 	const struct drm_edid *edid_override;
 
 	/**
-	 * @edid_override_mutex: Protect access to edid_override.
+	 * @non_desktop_override: Non-desktop override set via sysfs.
+	 *
+	 * Do not modify or access outside of the
+	 * drm_connector_non_desktop_override_* family of functions.
+	 */
+	enum drm_connector_non_desktop_override non_desktop_override;
+
+	/**
+	 * @edid_override_mutex: Protect access to edid_override and non_desktop_override.
 	 */
 	struct mutex edid_override_mutex;
 
-- 
2.54.0

