From 416e3d24544a3a3e27d402baca1c722599541c72 Mon Sep 17 00:00:00 2001
From: Gavin John <gavinnjohn@gmail.com>
Date: Fri, 17 Jul 2026 16:34:42 -0400
Subject: [PATCH 1/2] drm/edid: match on active resolution

---
 drivers/gpu/drm/drm_edid.c | 55 +++++++++++++++++++++++++++++++++++---
 include/drm/drm_edid.h     |  6 +++++
 2 files changed, 57 insertions(+), 4 deletions(-)

diff --git a/drivers/gpu/drm/drm_edid.c b/drivers/gpu/drm/drm_edid.c
index df3c25bac761..fb91ce70067c 100644
--- a/drivers/gpu/drm/drm_edid.c
+++ b/drivers/gpu/drm/drm_edid.c
@@ -149,6 +149,17 @@ struct drm_edid_match_closure {
 	.quirks = _quirks \
 }
 
+#define EDID_QUIRK_REQUIRE_RESOLUTION(vend_chr_0, vend_chr_1, vend_chr_2, product_id, \
+				      _resolution, _quirks) \
+{ \
+	.ident = { \
+		.panel_id = drm_edid_encode_panel_id(vend_chr_0, vend_chr_1, \
+						     vend_chr_2, product_id), \
+		.resolution = _resolution, \
+	}, \
+	.quirks = _quirks \
+}
+
 static const struct edid_quirk {
 	const struct drm_edid_ident ident;
 	u32 quirks;
@@ -5540,7 +5551,7 @@ drm_parse_hdmi_vsdb_audio(struct drm_connector *connector, const u8 *db)
 }
 
 static void
-match_identity(const struct detailed_timing *timing, void *data)
+match_identity_name(const struct detailed_timing *timing, void *data)
 {
 	struct drm_edid_match_closure *closure = data;
 	unsigned int i;
@@ -5568,6 +5579,28 @@ match_identity(const struct detailed_timing *timing, void *data)
 	closure->matched = true;
 }
 
+static void
+match_identity_resolution(const struct detailed_timing *timing, void *data)
+{
+	if (!is_detailed_timing_descriptor(timing))
+		return;
+
+	struct drm_edid_match_closure *closure = data;
+	const struct drm_edid_ident *ident = closure->ident;
+	const struct detailed_pixel_timing *pt = &timing->data.pixel_data;
+	u16 hactive = pt->hactive_lo |
+		((u16)(pt->hactive_hblank_hi >> 4) << 8);
+	u16 vactive = pt->vactive_lo |
+		((u16)(pt->vactive_vblank_hi >> 4) << 8);
+
+	if (hactive != ident->resolution.hactive)
+		return;
+	if (vactive != ident->resolution.vactive)
+		return;
+
+	closure->matched = true;
+}
+
 /**
  * drm_edid_match - match drm_edid with given identity
  * @drm_edid: EDID
@@ -5583,16 +5616,30 @@ bool drm_edid_match(const struct drm_edid *drm_edid,
 	if (!drm_edid || drm_edid_get_panel_id(drm_edid) != ident->panel_id)
 		return false;
 
-	/* Match with name only if it's not NULL. */
+	/* Match only when needed. */
 	if (ident->name) {
 		struct drm_edid_match_closure closure = {
 			.ident = ident,
 			.matched = false,
 		};
 
-		drm_for_each_detailed_block(drm_edid, match_identity, &closure);
+		drm_for_each_detailed_block(drm_edid, match_identity_name,
+					    &closure);
+
+		if (!closure.matched)
+			return false;
+	}
+	if (ident->resolution.hactive || ident->resolution.vactive) {
+		struct drm_edid_match_closure closure = {
+			.ident = ident,
+			.matched = false,
+		};
+
+		drm_for_each_detailed_block(drm_edid, match_identity_resolution,
+					    &closure);
 
-		return closure.matched;
+		if (!closure.matched)
+			return false;
 	}
 
 	return true;
diff --git a/include/drm/drm_edid.h b/include/drm/drm_edid.h
index 04f7a7f1f108..24aedb2c8ad4 100644
--- a/include/drm/drm_edid.h
+++ b/include/drm/drm_edid.h
@@ -333,11 +333,17 @@ struct edid {
 	u8 checksum;
 } __packed;
 
+struct drm_edid_ident_resolution {
+	u16 hactive;
+	u16 vactive;
+};
+
 /* EDID matching */
 struct drm_edid_ident {
 	/* ID encoded by drm_edid_encode_panel_id() */
 	u32 panel_id;
 	const char *name;
+	struct drm_edid_ident_resolution resolution;
 };
 
 #define DRM_EDID_IDENT_INIT(_vend_chr_0, _vend_chr_1, _vend_chr_2, _product_id, _name) \
-- 
2.54.0

